<body>
  <div class="container">
    <h1>Admin Feedback System</h1>
    <form id="feedbackForm">
      <label for="feedback">Submit Your Feedback:</label>
      <textarea id="feedback" name="feedback" placeholder="Enter your feedback here..."></textarea>
      <button type="submit">Submit Feedback</button>
    </form>
    <div id="response" class="response"></div>
    <div class="footer">
      &copy; 2026 Admin Feedback System v2.1.0
    </div>
  </div>

  <script>
    document.getElementById('feedbackForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const feedback = document.getElementById('feedback').value;
      const responseDiv = document.getElementById('response');

      try {
        const res = await fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ feedback })
        });

        const data = await res.json();

        if (res.ok) {
          responseDiv.className = 'response success';
          responseDiv.textContent = data.message;
        } else {
          responseDiv.className = 'response error';
          responseDiv.textContent = data.error || 'Submission failed';
        }
      } catch (err) {
        responseDiv.className = 'response error';
        responseDiv.textContent = 'Network error. Please try again.';
      }
    });
  </script>
</body>
</html>
