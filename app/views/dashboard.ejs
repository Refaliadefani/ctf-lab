<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; min-height: 100vh; }
    .navbar { background: #161b22; padding: 1rem 2rem; border-bottom: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center; }
    .navbar h2 { color: #58a6ff; }
    .navbar .user { color: #8b949e; }
    .main { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card h3 { color: #58a6ff; margin-bottom: 1rem; }
    .flag-container { background: #0d2818; border: 2px solid #2ea043; border-radius: 8px; padding: 1.5rem; margin-top: 1rem; }
    .flag-container code { color: #7ee787; font-size: 1.1rem; word-break: break-all; }
    .xss-payload { background: #1c1c1c; border: 1px solid #444; border-radius: 4px; padding: 1rem; margin-top: 1rem; font-family: monospace; color: #ff7b72; }
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .stat { text-align: center; padding: 1rem; background: #21262d; border-radius: 8px; }
    .stat .number { font-size: 2rem; font-weight: bold; color: #58a6ff; }
    .stat .label { color: #8b949e; font-size: 0.85rem; }
  </style>
</head>
<body>
  <nav class="navbar">
    <h2>Admin Dashboard</h2>
    <span class="user">Logged in as: <strong><%= user %></strong></span>
  </nav>

  <div class="main">
    <div class="card">
      <h3>System Statistics</h3>
      <div class="stats">
        <div class="stat">
          <div class="number">247</div>
          <div class="label">Total Feedback</div>
        </div>
        <div class="stat">
          <div class="number">12</div>
          <div class="label">Active Users</div>
        </div>
        <div class="stat">
          <div class="number">3</div>
          <div class="label">WAF Blocks Today</div>
        </div>
      </div>
    </div>

    <% if (feedback) { %>
    <div class="card">
      <h3>Latest Feedback Submission</h3>
      <!-- XSS Reflection Point - PHASE 3 flag: SCENARIO75{xss-payload} -->
      <div class="xss-payload"><%- feedback %></div>
    </div>
    <% } %>

    <div class="card">
      <h3>Administrative Controls</h3>
      <p style="color: #8b949e; margin-bottom: 1rem;">Restricted area - MFA verified session active.</p>
      <div class="flag-container">
        <p style="margin-bottom: 0.5rem; color: #2ea043; font-weight: bold;">🏁 Victory Flag:</p>
        <code><%= flag %></code>
      </div>
    </div>
  </div>
</body>
</html>
